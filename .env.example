# Supabase (server uses service role — never expose in client bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session signing (min 32 characters, random)
MORRA_SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Public site URL (Stripe success/cancel redirects, OpenRouter HTTP-Referer).
# Production (Vercel): set to your canonical URL, e.g. https://your-app.vercel.app or custom domain.
# On Vercel, VERCEL_URL is also used as fallback when this is unset (server-side only).
NEXT_PUBLIC_APP_URL=https://your-production-domain.example
# Local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — secret/server-only; publishable key is safe in client bundles (never put STRIPE_SECRET_KEY in client code)
STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Connect — Dashboard → Connect → Settings (client id for OAuth; optional for Express API onboarding)
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# Cron: release referral pending → available after 7-day hold (Vercel Cron or external scheduler)
# Send: Authorization: Bearer <CRON_SECRET> or header x-cron-secret: <CRON_SECRET>
CRON_SECRET=use-a-long-random-string

# Stripe Price IDs — must match Products/Prices in Dashboard (see src/lib/pricing.ts)
STRIPE_STARTER_PRICE_ID=price_starter
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_ELITE_PRICE_ID=price_elite

STRIPE_PRICE_CREDITS_SMALL=price_credits_small
STRIPE_PRICE_CREDITS_MEDIUM=price_credits_medium
STRIPE_PRICE_CREDITS_LARGE=price_credits_large
STRIPE_PRICE_CREDITS_POWER=price_credits_power

# AI — OpenRouter (server-only). Set key to enable; leave AI_PROVIDER unset or =openrouter
# https://openrouter.ai — use cheap models (see src/lib/ai/config.ts)
OPENROUTER_API_KEY=
# Sent as HTTP-Referer (OpenRouter policy). Production: https://morra.store
OPENROUTER_HTTP_REFERER=https://morra.store

# Optional: force mock with AI_PROVIDER=mock
# AI_PROVIDER=openrouter
